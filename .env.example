# ======================
# App
# ======================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ======================
# Database (PostgreSQL)
# ======================
DATABASE_URL=postgresql://user:password@localhost:5432/ora_events

# ======================
# Authentication (Better Auth)
# ======================
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000

# ======================
# SMTP / Email
# ======================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=ORA Events
SMTP_ENCRYPTION_KEY=your-32-byte-encryption-key

# ======================
# Resend (Email API)
# ======================
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@example.com
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ======================
# Infobip (SMS / Email / WhatsApp)
# ======================
INFOBIP_API_URL=https://xxxxx.api.infobip.com
INFOBIP_API_KEY=your-infobip-api-key
INFOBIP_SMS_FROM=ORA
INFOBIP_EMAIL_FROM=noreply@example.com

# ======================
# WhatsApp
# ======================
WHATSAPP_APP_SECRET=your-whatsapp-app-secret

# ======================
# Cloudflare R2 (File Storage)
# ======================
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=email-assets
CLOUDFLARE_R2_PUBLIC_URL=https://your-bucket.r2.dev

# ======================
# Azure AI (Concierge)
# ======================
AZURE_AI_ENDPOINT=https://your-endpoint.openai.azure.com
AZURE_AI_API_KEY=your-azure-ai-api-key
AZURE_DEPLOYMENT_NAME=gpt-4
CONCIERGE_ESCALATION_THRESHOLD=0.7

# ======================
# Google Maps
# ======================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ======================
# Cron / Vercel
# ======================
CRON_SECRET=your-cron-secret
VERCEL_CRON_SECRET=your-vercel-cron-secret
