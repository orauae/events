# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ======================
# Dependencies
# ======================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ======================
# Build & Output
# ======================
/.next/
/.kiro
/out/
/build
/dist

# ======================
# Testing & Coverage
# ======================
/coverage

# ======================
# Environment Variables
# ======================
.env
.env.*
!.env.example

# ======================
# OS Files
# ======================
.DS_Store
Thumbs.db

# ======================
# IDE & Editor
# ======================
.idea/
*.swp
*.swo
*~

# ======================
# Debug Logs
# ======================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ======================
# Security
# ======================
*.pem
*.key
*.cert

# ======================
# Vercel
# ======================
.vercel

# ======================
# TypeScript
# ======================
*.tsbuildinfo
next-env.d.ts

# ======================
# Prisma (if used)
# ======================
/app/generated/prisma

# ======================
# User Uploads (runtime data)
# ======================
/public/uploads/*
!/public/uploads/.gitkeep

# ======================
# Lock files (keep only one)
# ======================
# Using package-lock.json — ignore bun.lock
bun.lock

# ======================
# Drizzle
# ======================
drizzle/meta/_journal.json.bak
